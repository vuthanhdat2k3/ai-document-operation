# =============================================================================
# AI Document Operations Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# --- Application ---
APP_NAME=ai-doc-ops-agent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=docops
POSTGRES_USER=docops
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
REDIS_CACHE_TTL=3600

# --- Qdrant (Vector Database) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=change-me-qdrant-api-key
QDRANT_COLLECTION=document_chunks
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=documents
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# --- LLM Provider ---
# Supported: openai, anthropic, xiaomi, local
LLM_PROVIDER=xiaomi
LLM_MODEL=mimo-v2.5-pro
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
LLM_STREAMING=true

# OpenAI
OPENAI_API_KEY=sk-change-me-openai-key
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=change-me-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Xiaomi MiMo (Anthropic-compatible)
XIAOMI_API_KEY=change-me-xiaomi-token
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
XIAOMI_MODEL=mimo-v2.5-pro

# Local model (Ollama)
LOCAL_LLM_BASE_URL=http://ollama:11434

# Google Gemini
GEMINI_API_KEY=change-me-gemini-key

# Anthropic Claude
ANTHROPIC_API_KEY=change-me-anthropic-key

# Local model (Ollama)
LOCAL_LLM_BASE_URL=http://ollama:11434
LOCAL_LLM_MODEL=llama3

# --- Embedding Model ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=1024

# --- Reranker Model ---
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_TOP_K=5

# --- OCR ---
OCR_ENGINE=paddleocr
OCR_LANGUAGE=vi
OCR_USE_GPU=false
OCR_DET_DB_THRESH=0.3
OCR_DET_DB_BOX_THRESH=0.5
OCR_REC_BATCH_NUM=6

# --- Document Processing ---
MAX_FILE_SIZE_MB=50
SUPPORTED_FORMATS=pdf,docx,xlsx,png,jpg,jpeg,tiff
CHUNK_SIZE=512
CHUNK_OVERLAP=50
PARSING_TIMEOUT=300

# --- Agent ---
AGENT_MAX_ITERATIONS=10
AGENT_MAX_COST_PER_REQUEST=0.50
AGENT_ENABLE_HITL=true
AGENT_HITL_TIMEOUT=300

# --- Observability ---
LANGFUSE_PUBLIC_KEY=change-me-langfuse-public-key
LANGFUSE_SECRET_KEY=change-me-langfuse-secret-key
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_ENABLED=true

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=docops-backend
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# --- Security ---
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_PER_MINUTE=100

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI DocOps Agent
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# --- Worker ---
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY=60

# --- Email (placeholder, not used in MVP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change-me
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@example.com
